<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UNBEATABLEChartEditor.Dialogs.TextEntryDialog">
    <UserControl.Styles>
        <StyleInclude Source="/Dialogs/DialogStyles.axaml" />
    </UserControl.Styles>
    
    <Border Classes="Container">
        <Grid RowDefinitions="50, 50, 50" ColumnDefinitions="500" RowSpacing="10">
            <TextBlock Grid.Row="0" Name="Title" FontSize="42" />
            <TextBox Grid.Row="1" Name="TextBox" AcceptsReturn="False" />
            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <Button Classes="SquareIconButton" Click="ConfirmButtonClick">
                    <materialIcons:MaterialIcon Kind="Check" />
                </Button>
        
                <Button Classes="SquareIconButton" Click="CancelButtonClick">
                    <materialIcons:MaterialIcon Kind="Cancel" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
