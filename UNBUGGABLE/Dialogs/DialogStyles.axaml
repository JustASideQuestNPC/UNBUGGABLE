<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:dialogs="using:AvaloniaDialogs.Views">
    <Design.PreviewWith>
        <Border Padding="20">
            <!-- Add Controls for Previewer Here -->
        </Border>
    </Design.PreviewWith>
    
    <Styles.Resources>
        <SolidColorBrush x:Key="ComboBoxFlyoutPresenterBackground">Red</SolidColorBrush>
        <SolidColorBrush x:Key="ThemeBackgroundBrush">Red</SolidColorBrush>
    </Styles.Resources>
    
    <Style Selector="dialogs|BaseDialog">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    
    <Style Selector="Border.Container">
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        <Setter Property="Background" Value="{DynamicResource WindowBackgroundPrimary}" />
        <Setter Property="BorderThickness" Value="6" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10" />
    </Style>

    <Style Selector="Border.Container Button.SquareIconButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Width" Value="{Binding $self.Bounds.Height}" />
    </Style>
    <Style Selector="Border.Container Button.SquareIconButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource WindowBackgroundSecondary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    </Style>
    <Style Selector="Border.Container Button.SquareIconButton ToolTip">
        <Setter Property="Foreground" Value="{DynamicResource TextDark}" />
        <Setter Property="Background" Value="{DynamicResource WindowBackgroundPrimary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="FontFamily" Value="{DynamicResource RobotoMono}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="ShowDelay" Value="150" />
    </Style>
    <Style Selector="Border.Container materialIcons|MaterialIcon">
        <Setter Property="Foreground" Value="{DynamicResource Accent}" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="IconSize" Value="20" />
    </Style>
    <Style Selector="Border.Container Button.SquareIconButton:disabled materialIcons|MaterialIcon">
        <Setter Property="Opacity" Value="0.5" />
    </Style>
        
    <Style Selector="Border.Container TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource RobotoMono}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="Foreground" Value="{DynamicResource TextDark}" />
    </Style>
    
    <Style Selector="Border.Container TextBox">
        <Setter Property="FontFamily" Value="{StaticResource RobotoMono}" />
        <Setter Property="Foreground" Value="{DynamicResource TextDark}" />
        <Setter Property="Background" Value="{DynamicResource WindowBackgroundSecondary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="3" />
        <Setter Property="FontSize" Value="18" />
    </Style>
    <Style Selector="Border.Container TextBox:focus-within">
        <Setter Property="Foreground" Value="{DynamicResource TextDark}" />
        <Setter Property="CaretBrush" Value="{DynamicResource TextDark}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="3" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="Border.Container TextBox:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource TextDark}" />
        <Setter Property="CaretBrush" Value="{DynamicResource TextDark}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    </Style>
    <Style Selector="Border.Container TextBox:focus-within /template/ Border">
        <Setter Property="Background" Value="{DynamicResource WindowBackgroundSecondary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    </Style>
    <Style Selector="Border.Container TextBox:pointerover /template/ Border">
        <Setter Property="Background" Value="{DynamicResource WindowBackgroundSecondary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    </Style>
    
    <Style Selector="Border.Container TextBox.NumberBox">
        <Setter Property="FontFamily" Value="{StaticResource RobotoMono}" />
        <Setter Property="Foreground" Value="{DynamicResource TextDark}" />
        <Setter Property="Background" Value="{DynamicResource WindowBackgroundSecondary}" />
        <!-- <Setter Property="BorderBrush" Value="{DynamicResource Accent}" /> -->
        <!-- <Setter Property="BorderThickness" Value="2" /> -->
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="3" />
        <Setter Property="FontSize" Value="18" />
    </Style>
    <Style Selector="Border.Container TextBox.NumberBox:focus-within">
        <Setter Property="Foreground" Value="{DynamicResource TextDark}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="3" />
        <!-- <Setter Property="BorderBrush" Value="{DynamicResource Accent}" /> -->
        <!-- <Setter Property="BorderThickness" Value="2" /> -->
    </Style>
    <Style Selector="Border.Container TextBox.NumberBox:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource TextDark}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <!-- <Setter Property="VerticalAlignment" Value="Stretch" /> -->
        <!-- <Setter Property="BorderBrush" Value="{DynamicResource Accent}" /> -->
    </Style>
    <Style Selector="Border.Container TextBox.NumberBox:focus-within /template/ Border">
        <!-- <Setter Property="Background" Value="{DynamicResource WindowBackgroundSecondary}" /> -->
        <!-- <Setter Property="BorderBrush" Value="{DynamicResource Accent}" /> -->
    </Style>
    <Style Selector="Border.Container TextBox.NumberBox:pointerover /template/ Border">
        <!-- <Setter Property="Background" Value="{DynamicResource WindowBackgroundSecondary}" /> -->
        <!-- <Setter Property="BorderBrush" Value="{DynamicResource Accent}" /> -->
    </Style>
    
    <Style Selector="Border.Container NumericUpDown">
        <Setter Property="FontFamily" Value="{StaticResource RobotoMono}" />
        <Setter Property="Foreground" Value="{DynamicResource TextDark}" />
        <Setter Property="Background" Value="{DynamicResource WindowBackgroundSecondary}" />
        <!-- <Setter Property="BorderBrush" Value="{DynamicResource Accent}" /> -->
        <!-- <Setter Property="BorderThickness" Value="2" /> -->
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="3" />
        <Setter Property="FontSize" Value="18" />
    </Style>
    <Style Selector="Border.Container NumericUpDown:focus-within">
        <Setter Property="Foreground" Value="{DynamicResource TextDark}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="3" />
        <!-- <Setter Property="BorderBrush" Value="{DynamicResource Accent}" /> -->
        <!-- <Setter Property="BorderThickness" Value="2" /> -->
    </Style>
    <Style Selector="Border.Container NumericUpDown:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource TextDark}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <!-- <Setter Property="VerticalAlignment" Value="Stretch" /> -->
        <!-- <Setter Property="BorderBrush" Value="{DynamicResource Accent}" /> -->
    </Style>
    <Style Selector="Border.Container NumericUpDown:focus-within /template/ Border">
        <!-- <Setter Property="Background" Value="{DynamicResource WindowBackgroundSecondary}" /> -->
        <!-- <Setter Property="BorderBrush" Value="{DynamicResource Accent}" /> -->
    </Style>
    <Style Selector="Border.Container NumericUpDown:pointerover /template/ Border">
        <!-- <Setter Property="Background" Value="{DynamicResource WindowBackgroundSecondary}" /> -->
        <!-- <Setter Property="BorderBrush" Value="{DynamicResource Accent}" /> -->
    </Style>
    
    <Style Selector="Border.Container ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource RobotoMono}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="Background" Value="{DynamicResource WindowBackgroundSecondary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>
    
    <Style Selector="Border.Container ComboBox:dropdownopen /template/ Popup#PART_Popup > Border">
        <Setter Property="Background" Value="{DynamicResource WindowBackgroundSecondary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>
    
    <Style Selector="Border.Container ComboBoxItem">
        <Setter Property="FontFamily" Value="{StaticResource RobotoMono}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>
</Styles>
